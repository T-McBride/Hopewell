[Unit]
Description=Contact directory kiosk backend
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/contact-kiosk
Environment=PATH=/home/pi/contact-kiosk/venv/bin
ExecStart=/home/pi/contact-kiosk/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
